---
// =========================================================================
// 🏛️ REPUBLIK PORTAL SIAKAD - MODUL KASIR UPDATE SPP MAHASISWA (SERVER SSR)
// 🎓 STIT YA'MAL TANGERANG - ASTRO V6 + REAL-TIME FINANCIAL D1 MUTATOR
// =========================================================================

import { env } from 'cloudflare:workers';

let pesanSukses = "";
let pesanEror = "";
let daftarInvoiceSpp: any[] = [];

// 🛡️ GATEKEEPER PROTECTION: Kunci hak akses ketat hanya untuk Admin BAAK / Kasir
const sessionNim = Astro.cookies.get("siakad_session_nim")?.value;
const sessionNama = Astro.cookies.get("siakad_session_nama")?.value;
const sessionRole = Astro.cookies.get("siakad_session_role")?.value;

if (!sessionNim || sessionRole !== "admin") {
  return Astro.redirect('/login');
}

const db = env.database_siakad;
if (!db) {
  return Astro.json({ error: "Database binding tidak ditemukan." }, { status: 500 });
}

// 📡 PROSES MUTASI METODE POST: Eksekusi Update Status SPP Keuangan di Rahim D1
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const krsIndukId = formData.get("krs_induk_id");
    const statusBaru = formData.get("status_spp_baru");

    if (!krsIndukId || !statusBaru) {
      throw new Error("Parameter invoice finansial tidak lengkap, Doc!");
    }

    // Tembakkan kueri UPDATE ke tabel krs_induk khusus kolom status_spp
    await db.prepare(`
      UPDATE krs_induk 
      SET status_spp = ? 
      WHERE id = ?
    `).bind(statusBaru, krsIndukId).run();

    // 🛡️ CYBER FORENSICS LOG INJECTION AUTO-TRACKER
    const headers = Astro.request.headers;
    const liveIpAddress = headers.get("cf-connecting-ip") || headers.get("x-forwarded-for") || "127.0.0.1";
    await db.prepare(`
      INSERT INTO riwayat_audit_siakad (nama_pengguna, peran_pengguna, aksi_aktivitas, alamat_ip)
      VALUES (?, ?, ?, ?)
    `).bind(sessionNama, sessionRole, `Mengubah status billing keuangan SPP Invoice ID #${krsIndukId} menjadi ${statusBaru.toUpperCase()}`, liveIpAddress).run();

    pesanSukses = "✓ Berhasil mengunci mutasi keuangan kasir terbaru ke database Cloudflare D1!";
  } catch (error: any) {
    pesanEror = `Gagal memproses mutasi kasir: ${error.message}`;
  }
}

try {
  // 🔍 REAL-TIME SQL RELATIONAL JOIN: Tarik data tagihan SPP mahasiswa aktif
  const sppQuery = await db.prepare(`
    SELECT ki.id as krs_induk_id, ps.nama_lengkap, ps.nomor_induk as nim, ki.status_spp, ki.tahun_akademik
    FROM krs_induk ki
    JOIN pengguna_siakad ps ON ki.mahasiswa_id = ps.id
    ORDER BY ki.id DESC
  `).all();
  daftarInvoiceSpp = sppQuery.results || [];
} catch (error: any) {
  pesanEror = `Gagal sinkronisasi pangkalan kasir D1: ${error.message}`;
}
---
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Kasir Keuangan Update SPP - SIAKAD STIT YA'MAL</title>
  </head>
  <body style="margin: 0; background-color: #f4f9fa; font-family: sans-serif; color: #1f2937;">
    
    <!-- TOP BAR PANEL NAVIGASI CENTRAL BAAK HUB -->
    <header style="background-color: #005d6c; color: #ffffff; padding: 16px 32px; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
      <div style="font-weight: 800; font-size: 1.2rem; letter-spacing: -0.3px;"><a href="/admin/dashboard" style="color: #ffffff; text-decoration: none;">🏛️ Central BAAK Hub</a> ➔ KASIR KEUANGAN SPP</div>
      <div style="font-size: 0.9rem; font-weight: 600;">💰 {sessionNama}</div>
    </header>

    <main style="max-width: 1100px; margin: 0 auto; padding: 40px 20px; display: flex; flex-direction: column; gap: 30px;">
      
      {pesanSukses && <div style="padding: 14px; background-color: #dcfce7; border: 1px solid #bbf7d0; color: #15803d; font-weight: bold; border-radius: 8px; font-size: 0.88rem; line-height: 1.4;">{pesanSukses}</div>}
      {pesanEror && <div style="padding: 14px; background-color: #fee2e2; border: 1px solid #fca5a5; color: #991b1b; font-weight: bold; border-radius: 8px; font-size: 0.88rem; line-height: 1.4;">{pesanEror}</div>}

      <!-- HEADER PENJELASAN MODUL KASIR -->
      <div style="background-color: #ffffff; padding: 32px; border-radius: 16px; border: 1px solid #e5e7eb; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.01);">
        <div style="border-bottom: 2px solid #f1f5f9; padding-bottom: 12px; margin-bottom: 24px;">
          <h2 style="margin: 0; color: #005d6c; font-weight: 800; font-size: 1.4rem;">💵 Kontrol Loket Pembayaran SPP Mahasiswa</h2>
          <p style="margin: 4px 0 0 0; color: #64748b; font-size: 0.85rem;">Validasi bukti transfer bank atau pembayaran tunai dari mahasiswa. Mengubah status di sini otomatis memperbarui hak cetak KRS dan grafik diagram kas utama [dan-cf-workers-d1].</p>
        </div>

        <div style="overflow-x: auto;">
          <table style="width: 100%; border-collapse: collapse; font-size: 0.9rem; text-align: left; min-width: 800px;">
            <thead>
              <tr style="border-bottom: 2px solid #e5e7eb; color: #005d6c; font-weight: bold; background-color: #f8fafc;">
                <th style="padding: 14px 12px; width: 100px;">INVOICE ID</th>
                <th style="padding: 14px 12px; width: 140px;">NIM MAHASISWA</th>
                <th style="padding: 14px 12px;">NAMA LENGKAP MAHASISWA</th>
                <th style="padding: 14px 12px; width: 130px;">TAHUN AJARAN</th>
                <th style="padding: 14px 12px; text-align: center; width: 150px;">STATUS KAS SEKARANG</th>
                <th style="padding: 14px 12px; text-align: center; width: 200px;">AKSI MUTASI LOKET</th>
              </tr>
            </thead>
            <tbody>
              {daftarInvoiceSpp.length === 0 ? (
                <tr>
                  <td colspan="6" style="padding: 24px; text-align: center; color: #64748b; font-style: italic;">
                    Belum ada riwayat berkas tagihan invoice SPP mahasiswa yang tercatat di sistem, Doc.
                  </td>
                </tr>
              ) : (
                daftarInvoiceSpp.map((inv) => (
                  <tr style="border-bottom: 1px solid #f1f5f9;">
                    <td style="padding: 14px 12px; font-weight: bold; color: #475569; font-family: monospace;">#{inv.krs_induk_id}</td>
                    <td style="padding: 14px 12px; font-weight: bold; color: #0284c7; font-family: monospace;">{inv.nim}</td>
                    <td style="padding: 14px 12px; font-weight: 600; color: #111827;">👤 {inv.nama_lengkap}</td>
                    <td style="padding: 14px 12px; font-weight: 500; color: #4b5563;">{inv.tahun_akademik}</td>
                    <td style="padding: 14px 12px; text-align: center;">
                      <!-- BADGE HISTOGRAM STATUS LIVE WARNA FINANSIAL -->
                      <span style={`padding: 6px 10px; border-radius: 6px; font-size: 0.78rem; font-weight: bold; text-transform: uppercase; display: inline-block; ${inv.status_spp === 'lunas' ? 'background-color: #dcfce7; color: #15803d; border: 1px solid #bbf7d0;' : 'background-color: #fee2e2; color: #991b1b; border: 1px solid #fca5a5;'}`}>
                        {inv.status_spp === 'lunas' ? '✓ LUNAS SAH' : '⚠️ TUNGGAKAN'}
                      </span>
                    </td>
                    <td style="padding: 14px 12px; text-align: center;">
                      <!-- FORM SAKLAR DIRECT IN-LINE MUTATOR AUTOMATION -->
                      <form method="POST" style="margin: 0; display: flex; gap: 8px; justify-content: center; align-items: center;">
                        <input type="hidden" name="krs_induk_id" value={inv.krs_induk_id} />
                        <select name="status_spp_baru" style="padding: 6px 8px; border-radius: 6px; border: 1px solid #cbd5e1; font-size: 0.82rem; background-color: #ffffff; cursor: pointer; outline: none;">
                          <option value="tunggakan" selected={inv.status_spp === 'tunggakan'}>⚠️ Tunggakan</option>
                          <option value="lunas" selected={inv.status_spp === 'lunas'}>✓ Lunas Sah</option>
                        </select>
                        <button type="submit" style="padding: 6px 12px; background-color: #005d6c; color: #ffffff; border: none; border-radius: 6px; font-size: 0.82rem; font-weight: bold; cursor: pointer; transition: background-color 0.1s;" onmouseover="this.style.backgroundColor='#0b6170'" onmouseout="this.style.backgroundColor='#005d6c'">
                          Ubah
                        </button>
                      </form>
                    </td>
                  </tr>
                ))
              )}
            </tbody>
          </table>
        </div>

        <div style="margin-top: 32px; text-align: center; border-top: 1px solid #f1f5f9; padding-top: 20px;">
          <a href="/admin/dashboard" style="color: #64748b; font-size: 0.9rem; font-weight: 600; text-decoration: none;">➔ Kembali ke BAAK HUB Dashboard</a>
        </div>
      </div>

    </main>
  </body>
</html>
