---
// =========================================================================
// 🏛️ REPUBLIK PORTAL SIAKAD - MANAJEMEN DATA MAHASISWA BAAK (SERVER SSR)
// 🎓 STIT YA'MAL TANGERANG - ASTRO V6 + REAL-TIME D1 STUDENT REGISTRATION
// =========================================================================

import { env } from 'cloudflare:workers';

let pesanSukses = "";
let pesanEror = "";
let daftarMahasiswa: any[] = [];

// 🛡️ GATEKEEPER PROTECTION: Kunci hak akses ketat hanya untuk Admin BAAK
const sessionNim = Astro.cookies.get("siakad_session_nim")?.value;
const sessionNama = Astro.cookies.get("siakad_session_nama")?.value;
const sessionRole = Astro.cookies.get("siakad_session_role")?.value;

if (!sessionNim || sessionRole !== "admin") {
  return Astro.redirect('/login');
}

const db = env.database_siakad;
if (!db) {
  return Astro.json({ error: "Database binding tidak ditemukan." }, { status: 500 });
}

// 📡 PROSES MUTASI METODE POST: Daftarkan Mahasiswa Baru ke Rahim Database D1
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const nim = formData.get("nim_baru")?.trim();
    const nama = formData.get("nama_lengkap")?.trim();
    const wa = formData.get("nomor_wa")?.trim();
    const sandi = formData.get("kata_sandi")?.trim() || "sandi_mahasiswa_123";
    
    // 📸 KAWAT PIPELINE PENANGKAP PAS FOTO BINARY FILE KE CLOUDFLARE R2
    const fotoFile = formData.get("foto_mahasiswa") as File;
    let urlFotoR2 = "/images/default-avatar.png"; // Default fallback avatar

    if (fotoFile && fotoFile.size > 0) {
      const r2Bucket = env.storage_brosur_yamal; // Memanggil binding r2_buckets dari wrangler.jsonc
      
      if (!r2Bucket) {
        throw new Error("Binding R2 Storage Bucket 'storage_brosur_yamal' belum terbaca di serverless runtime, Chief!");
      }

      const extension = fotoFile.name.split('.').pop();
      const namaFileUnik = `avatar_${Date.now()}.${extension}`;

      // 🚀 DIRECT BINARY INJECTION STREAM INTO CLOUDFLARE R2 BUCKET
      const arrayBufferFile = await fotoFile.arrayBuffer();
      await r2Bucket.put(namaFileUnik, arrayBufferFile, {
        httpMetadata: { contentType: fotoFile.type }
      });

      urlFotoR2 = `/cdn-assets/${namaFileUnik}`;
    }

    // 1. Tembakkan kueri INSERT masuk ke dalam tabel pengguna_siakad + Kolom foto_url baru
    await db.prepare(`
      INSERT INTO pengguna_siakad (nomor_induk, kata_sandi, nama_lengkap, peran, nomor_wa, foto_url) 
      VALUES (?, ?, ?, 'mahasiswa', ?, ?)
    `).bind(nim, sandi, nama, wa, urlFotoR2).run();

    // 2. AUTO-SEED SEKTOR FINANSIAL KHS: Daftarkan baris induk KRS baru agar otomatis punya billing SPP pokok
    const userTerbaru: any = await db.prepare("SELECT id FROM pengguna_siakad WHERE nomor_induk = ? LIMIT 1").bind(nim).first();
    if (userTerbaru) {
      await db.prepare(`
        INSERT INTO krs_induk (mahasiswa_id, semester_berjalan, status_krs, status_spp) 
        VALUES (?, 1, 'draft', 'tunggakan')
      `).bind(userTerbaru.id).run();
    }

    // 🛡️ CYBER FORENSICS LOG INJECTION AUTO-TRACKER
    const headers = Astro.request.headers;
    const liveIpAddress = headers.get("cf-connecting-ip") || headers.get("x-forwarded-for") || "127.0.0.1";
    await db.prepare(`
      INSERT INTO riwayat_audit_siakad (nama_pengguna, peran_pengguna, aksi_aktivitas, alamat_ip)
      VALUES (?, ?, ?, ?)
    `).bind(sessionNama, sessionRole, `Mendaftarkan mahasiswa baru: ${nama} (NIM: ${nim}) dengan unggahan foto profil resmi ke R2`, liveIpAddress).run();

    pesanSukses = `✓ Pendaftaran Berhasil! Mahasiswa bernama ${nama} dengan NIM ${nim} beserta pas foto R2 resmi terdaftar di database D1!`;
  } catch (error: any) {
    pesanEror = `Gagal memproses pendaftaran civitas baru: ${error.message}`;
  }
}

try {
  // 🔍 STREAM DATA UTAMA: Tarik daftar seluruh mahasiswa termasuk field foto_url baru untuk di-render ke datatable bawah
  const mhsQuery = await db.prepare(`
    SELECT ps.id, ps.nomor_induk, ps.nama_lengkap, ps.nomor_wa, ps.foto_url, ki.status_spp, ki.status_krs
    FROM pengguna_siakad ps
    LEFT JOIN krs_induk ki ON ps.id = ki.mahasiswa_id
    WHERE ps.peran = 'mahasiswa'
    ORDER BY ps.id DESC
  `).all();
  daftarMahasiswa = mhsQuery.results || [];
} catch (error: any) {
  pesanEror = `Gagal sinkronisasi pangkalan data D1: ${error.message}`;
}
---
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Manajemen Data Mahasiswa - SIAKAD STIT YA'MAL</title>
  </head>
  <body style="margin: 0; background-color: #f4f9fa; font-family: sans-serif; color: #1f2937;">
    
    <!-- TOP BAR PANEL NAVIGASI SULTAN -->
    <header style="background-color: #005d6c; color: #ffffff; padding: 16px 32px; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
      <div style="font-weight: 800; font-size: 1.2rem; letter-spacing: -0.3px;"><a href="/admin/dashboard" style="color: #ffffff; text-decoration: none;">🏛️ Central BAAK Hub</a> ➔ MANAJEMEN MAHASISWA</div>
      <div style="font-size: 0.9rem; font-weight: 600;">⚙️ {sessionNama}</div>
    </header>

    <main style="max-width: 1100px; margin: 0 auto; padding: 40px 20px; display: flex; flex-direction: column; gap: 30px;">
      
      {pesanSukses && <div style="padding: 14px; background-color: #dcfce7; border: 1px solid #bbf7d0; color: #15803d; font-weight: bold; border-radius: 8px; font-size: 0.88rem;">{pesanSukses}</div>}
      {pesanEror && <div style="padding: 14px; background-color: #fee2e2; border: 1px solid #fca5a5; color: #991b1b; font-weight: bold; border-radius: 8px; font-size: 0.88rem;">{pesanEror}</div>}

      <!-- FORMULIR PENDAFTARAN CIVITAS MAHASISWA BARU -->
      <div style="background-color: #ffffff; padding: 32px; border-radius: 16px; border: 1px solid #e5e7eb; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.01);">
        <div style="border-bottom: 2px solid #f1f5f9; padding-bottom: 12px; margin-bottom: 24px;">
          <h2 style="margin: 0; color: #005d6c; font-weight: 800; font-size: 1.4rem;">➕ Daftarkan Mahasiswa Baru (PMB)</h2>
          <p style="margin: 4px 0 0 0; color: #64748b; font-size: 0.85rem;">Input basis data identitas mahasiswa baru untuk membuka akses portal akademik SIAKAD dan pembuatan billing keuangan.</p>
        </div>

        <!-- 🟢 SUNTIKAN ATRIBUT ENCTYPE MULTIPART UNTUK STREAM FILE BINARY FOTO R2 -->
        <form method="POST" enctype="multipart/form-data" style="margin: 0; display: flex; flex-direction: column; gap: 20px;">
          
          <!-- GRID BARIS 1: NIM & NAMA MAHASISWA -->
          <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 20px; flex-wrap: wrap;">
            <div style="display: flex; flex-direction: column; gap: 6px;">
              <label style="font-size: 0.8rem; font-weight: bold; color: #475569; text-transform: uppercase;">Nomor Induk Mahasiswa (NIM)</label>
              <input type="text" name="nim_baru" placeholder="Contoh: 202610002" required style="padding: 12px; border-radius: 8px; border: 1px solid #cbd5e1; font-size: 0.92rem; color: #0f172a; outline: none;" />
            </div>
            <div style="display: flex; flex-direction: column; gap: 6px;">
              <label style="font-size: 0.8rem; font-weight: bold; color: #475569; text-transform: uppercase;">Nama Lengkap Mahasiswa</label>
              <input type="text" name="nama_lengkap" placeholder="Contoh: Ahmad Fauzi, S.Kom" required style="padding: 12px; border-radius: 8px; border: 1px solid #cbd5e1; font-size: 0.92rem; color: #0f172a; outline: none;" />
            </div>
          </div>

          <!-- 🟢 SUNTIKAN BARIS INPUT FILE FISIK FOTO PROFIL MAHASISWA BARU (KASTA SULTAN!) -->
          <div style="display: flex; flex-direction: column; gap: 6px;">
            <label style="font-size: 0.8rem; font-weight: bold; color: #475569; text-transform: uppercase; letter-spacing: 0.3px;">📸 Pas Foto Resmi Kartu Tanda Mahasiswa (KTM) / Ijazah (Max 2MB):</label>
            <input type="file" name="foto_mahasiswa" accept="image/*" style="padding: 12px; border-radius: 8px; border: 1px solid #cbd5e1; font-size: 0.92rem; background-color: #f8fafc; color: #475569; cursor: pointer; outline: none;" />
          </div>
          <!-- GRID BARIS 2: NOMOR WA & KATA SANDI -->
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; flex-wrap: wrap; margin-top: 20px;">
            <div style="display: flex; flex-direction: column; gap: 6px;">
              <label style="font-size: 0.8rem; font-weight: bold; color: #475569; text-transform: uppercase;">Nomor WhatsApp Aktif</label>
              <input type="tel" name="nomor_wa" placeholder="Contoh: 081234567890" required style="padding: 12px; border-radius: 8px; border: 1px solid #cbd5e1; font-size: 0.92rem; color: #0f172a; outline: none;" />
            </div>
            <div style="display: flex; flex-direction: column; gap: 6px;">
              <label style="font-size: 0.8rem; font-weight: bold; color: #475569; text-transform: uppercase;">Kata Sandi Akun (Default)</label>
              <input type="text" name="kata_sandi" placeholder="Kosongkan untuk otomatis: sandi_mahasiswa_123" style="padding: 12px; border-radius: 8px; border: 1px solid #cbd5e1; font-size: 0.92rem; color: #0f172a; outline: none;" />
            </div>
          </div>

          <!-- TOMBOL SUBMIT EKSEKUTOR -->
          <button type="submit" style="margin-top: 10px; padding: 14px; background-color: #005d6c; color: #ffffff; border: none; border-radius: 8px; font-size: 0.95rem; font-weight: bold; cursor: pointer; transition: background-color 0.15s; box-shadow: 0 4px 6px -1px rgba(0, 93, 108, 0.15);" onmouseover="this.style.backgroundColor='#0b6170'" onmouseout="this.style.backgroundColor='#005d6c'">
            🚀 Daftarkan & Validasi Mahasiswa Baru ➔
          </button>

        </form>
      </div>

      <!-- DATA TABLE: DAFTAR CIVITAS MAHASISWA AKTIF -->
      <div style="background-color: #ffffff; border-radius: 16px; border: 1px solid #e5e7eb; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.01); overflow: hidden;">
        <div style="padding: 24px; background-color: #f8fafc; border-bottom: 1px solid #e5e7eb;">
          <h3 style="margin: 0; color: #005d6c; font-weight: 800; font-size: 1.15rem;">👨‍🎓 Berkas Database Mahasiswa Aktif</h3>
        </div>

        <div style="overflow-x: auto;">
          <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.9rem;">
            <thead>
              <tr style="background-color: #f1f5f9; color: #475569; font-weight: bold; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px;">
                <th style="padding: 16px 24px;">Profil & Nama Lengkap</th>
                <th style="padding: 16px 24px;">NIM</th>
                <th style="padding: 16px 24px;">Kontak WA</th>
                <th style="padding: 16px 24px;">Status SPP</th>
                <th style="padding: 16px 24px;">Akses KRS</th>
              </tr>
            </thead>
            <tbody>
              {daftarMahasiswa.map((item) => (
                <tr style="border-bottom: 1px solid #f1f5f9; transition: background-color 0.1s;" onmouseover="this.style.backgroundColor='#f8fafc';" onmouseout="this.style.backgroundColor='transparent';">
                  
                  <!-- 📸 KOLOM PROFIL: RENDER AVATAR MINI DIGITAL HASIL TRANSPLANTASI R2 COuPLING -->
                  <td style="padding: 16px 24px; display: flex; align-items: center; gap: 12px;">
                    <div style="width: 40px; height: 40px; border-radius: 50%; overflow: hidden; border: 2px solid #e2e8f0; background-color: #f1f5f9; flex-shrink: 0; display: flex; align-items: center; justify-content: center;">
                      <img 
                        src={item.foto_url || "/images/default-avatar.png"} 
                        alt={item.nama_lengkap}
                        style="width: 100%; height: 100%; object-fit: cover;"
                        onerror="this.src='/images/default-avatar.png';"
                      />
                    </div>
                    <div>
                      <div style="font-weight: 700; color: #0f172a;">{item.nama_lengkap}</div>
                      <div style="font-size: 0.75rem; color: #64748b; margin-top: 2px;">Aktif Ganjil</div>
                    </div>
                  </td>

                  <td style="padding: 16px 24px; font-weight: 600; color: #334155; font-family: monospace; font-size: 0.95rem;">{item.nomor_induk}</td>
                  <td style="padding: 16px 24px; color: #475569;">🟢 {item.nomor_wa}</td>
                  
                  <td style="padding: 16px 24px;">
                    <span style={`padding: 4px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: bold; text-transform: uppercase; ${item.status_spp === 'lunas' ? 'background-color: #dcfce7; color: #15803d; border: 1px solid #bbf7d0;' : 'background-color: #fee2e2; color: #991b1b; border: 1px solid #fca5a5;'}`}>
                      {item.status_spp}
                    </span>
                  </td>
                  
                  <td style="padding: 16px 24px;">
                    <span style={`padding: 4px 10px; border-radius: 6px; font-size: 0.75rem; font-weight: bold; text-transform: uppercase; ${item.status_krs === 'disetujui' ? 'background-color: #e0f2fe; color: #0369a1;' : item.status_krs === 'diajukan' ? 'background-color: #fef3c7; color: #b45309;' : 'background-color: #f1f5f9; color: #64748b;'}`}>
                      {item.status_krs}
                    </span>
                  </td>

                </tr>
              ))}
            </tbody>
          </table>
          {daftarMahasiswa.length === 0 && (
            <div style="padding: 40px; text-align: center; color: #94a3b8; font-size: 0.9rem; font-style: italic;">Belum ada civitas mahasiswa yang terdaftar di sistem BAAK.</div>
          )}
        </div>
      </div>

    </main>
  </body>
</html>
