---
// =========================================================================
// 🏛️ REPUBLIK PORTAL SIAKAD - MANAJEMEN DATA MAHASISWA BAAK (SERVER SSR)
// 🎓 STIT YA'MAL TANGERANG - ASTRO V6 + REAL-TIME D1 STUDENT REGISTRATION
// =========================================================================

import { env } from 'cloudflare:workers';

let pesanSukses = "";
let pesanEror = "";
let daftarMahasiswa: any[] = [];

// 🛡️ GATEKEEPER PROTECTION: Kunci hak akses ketat hanya untuk Admin BAAK
const sessionNim = Astro.cookies.get("siakad_session_nim")?.value;
const sessionNama = Astro.cookies.get("siakad_session_nama")?.value;
const sessionRole = Astro.cookies.get("siakad_session_role")?.value;

if (!sessionNim || sessionRole !== "admin") {
  return Astro.redirect('/login');
}

const db = env.database_siakad;
if (!db) {
  return Astro.json({ error: "Database binding tidak ditemukan." }, { status: 500 });
}

// 📡 PROSES MUTASI METODE POST: Daftarkan Mahasiswa Baru ke Rahim Database D1
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const nim = formData.get("nim_baru")?.trim();
    const nama = formData.get("nama_lengkap")?.trim();
    const wa = formData.get("nomor_wa")?.trim();
    const sandi = formData.get("kata_sandi")?.trim() || "sandi_mahasiswa_123";

    // 1. Tembakkan kueri INSERT masuk ke dalam tabel pengguna_siakad kasta sultan
    await db.prepare(`
      INSERT INTO pengguna_siakad (nomor_induk, kata_sandi, nama_lengkap, peran, nomor_wa) 
      VALUES (?, ?, ?, 'mahasiswa', ?)
    `).bind(nim, sandi, nama, wa).run();

    // 2. AUTO-SEED SEKTOR FINANSIAL KHS: Daftarkan baris induk KRS baru agar otomatis punya billing SPP pokok
    // Catatan: Mencari ID baris terakhir yang baru saja ter-insert
    const userTerbaru: any = await db.prepare("SELECT id FROM pengguna_siakad WHERE nomor_induk = ? LIMIT 1").bind(nim).first();
    if (userTerbaru) {
      await db.prepare(`
        INSERT INTO krs_induk (mahasiswa_id, semester_berjalan, status_krs, status_spp) 
        VALUES (?, 1, 'draft', 'tunggakan')
      `).bind(userTerbaru.id).run();
    }

    // 🛡️ CYBER FORENSICS LOG INJECTION AUTO-TRACKER
    const headers = Astro.request.headers;
    const liveIpAddress = headers.get("cf-connecting-ip") || headers.get("x-forwarded-for") || "127.0.0.1";
    await db.prepare(`
      INSERT INTO riwayat_audit_siakad (nama_pengguna, peran_pengguna, aksi_aktivitas, alamat_ip)
      VALUES (?, ?, ?, ?)
    `).bind(sessionNama, sessionRole, `Mendaftarkan mahasiswa baru: ${nama} (NIM: ${nim}) ke dalam sistem SIAKAD`, liveIpAddress).run();

    pesanSukses = `✓ Pendaftaran Berhasil! Mahasiswa bernama ${nama} dengan NIM ${nim} resmi terdaftar di database D1!`;
  } catch (error: any) {
    pesanEror = `Gagal memproses pendaftaran civitas baru: ${error.message}`;
  }
}

try {
  // 🔍 STREAM DATA UTAMA: Tarik daftar seluruh mahasiswa untuk di-render ke datatable bawah
  const mhsQuery = await db.prepare(`
    SELECT ps.id, ps.nomor_induk, ps.nama_lengkap, ps.nomor_wa, ki.status_spp, ki.status_krs
    FROM pengguna_siakad ps
    LEFT JOIN krs_induk ki ON ps.id = ki.mahasiswa_id
    WHERE ps.peran = 'mahasiswa'
    ORDER BY ps.id DESC
  `).all();
  daftarMahasiswa = mhsQuery.results || [];
} catch (error: any) {
  pesanEror = `Gagal sinkronisasi pangkalan data D1: ${error.message}`;
}
---
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Manajemen Data Mahasiswa - SIAKAD STIT YA'MAL</title>
  </head>
  <body style="margin: 0; background-color: #f4f9fa; font-family: sans-serif; color: #1f2937;">
    
    <!-- TOP BAR PANEL NAVIGASI SULTAN -->
    <header style="background-color: #005d6c; color: #ffffff; padding: 16px 32px; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
      <div style="font-weight: 800; font-size: 1.2rem; letter-spacing: -0.3px;"><a href="/admin/dashboard" style="color: #ffffff; text-decoration: none;">🏛️ Central BAAK Hub</a> ➔ MANAJEMEN MAHASISWA</div>
      <div style="font-size: 0.9rem; font-weight: 600;">⚙️ {sessionNama}</div>
    </header>

    <main style="max-width: 1100px; margin: 0 auto; padding: 40px 20px; display: flex; flex-direction: column; gap: 30px;">
      
      {pesanSukses && <div style="padding: 14px; background-color: #dcfce7; border: 1px solid #bbf7d0; color: #15803d; font-weight: bold; border-radius: 8px; font-size: 0.88rem;">{pesanSukses}</div>}
      {pesanEror && <div style="padding: 14px; background-color: #fee2e2; border: 1px solid #fca5a5; color: #991b1b; font-weight: bold; border-radius: 8px; font-size: 0.88rem;">{pesanEror}</div>}

      <!-- FORMULIR PENDAFTARAN CIVITAS MAHASISWA BARU -->
      <div style="background-color: #ffffff; padding: 32px; border-radius: 16px; border: 1px solid #e5e7eb; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.01);">
        <div style="border-bottom: 2px solid #f1f5f9; padding-bottom: 12px; margin-bottom: 24px;">
          <h2 style="margin: 0; color: #005d6c; font-weight: 800; font-size: 1.4rem;">➕ Daftarkan Mahasiswa Baru (PMB)</h2>
          <p style="margin: 4px 0 0 0; color: #64748b; font-size: 0.85rem;">Input basis data identitas mahasiswa baru untuk membuka akses portal akademik SIAKAD dan pembuatan billing keuangan.</p>
        </div>

        <form method="POST" style="display: flex; flex-direction: column; gap: 20px;">
          
          <!-- GRID BARIS 1: NIM & NAMA MAHASISWA -->
          <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 20px; flex-wrap: wrap;">
            <div style="display: flex; flex-direction: column; gap: 6px;">
              <label style="font-size: 0.8rem; font-weight: bold; color: #475569; text-transform: uppercase;">Nomor Induk Mahasiswa (NIM)</label>
              <input type="text" name="nim_baru" placeholder="Contoh: 202610002" required style="padding: 12px; border-radius: 8px; border: 1px solid #cbd5e1; font-size: 0.92rem; color: #0f172a; outline: none;" />
            </div>
            <div style="display: flex; flex-direction: column; gap: 6px;">
              <label style="font-size: 0.8rem; font-weight: bold; color: #475569; text-transform: uppercase;">Nama Lengkap Mahasiswa</label>
              <input type="text" name="nama_lengkap" placeholder="Contoh: Ahmad Fauzi, S.Kom" required style="padding: 12px; border-radius: 8px; border: 1px solid #cbd5e1; font-size: 0.92rem; color: #0f172a; outline: none;" />
            </div>
          </div>

          <!-- GRID BARIS 2: NOMOR WA & KATA SANDI FALLBACK -->
          <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px;">
            <div style="display: flex; flex-direction: column; gap: 6px;">
              <label style="font-size: 0.8rem; font-weight: bold; color: #475569; text-transform: uppercase;">Nomor WhatsApp Aktif (Format 62)</label>
              <input type="text" name="nomor_wa" placeholder="Contoh: 628123456789" required style="padding: 12px; border-radius: 8px; border: 1px solid #cbd5e1; font-size: 0.92rem; color: #0f172a; outline: none;" />
            </div>
            <div style="display: flex; flex-direction: column; gap: 6px;">
              <label style="font-size: 0.8rem; font-weight: bold; color: #475569; text-transform: uppercase;">Kata Sandi Default Portal</label>
              <input type="text" name="kata_sandi" value="sandi_mahasiswa_123" required style="padding: 12px; border-radius: 8px; border: 1px solid #cbd5e1; font-size: 0.92rem; color: #475569; background-color: #f8fafc; outline: none;" />
            </div>
          </div>

          <!-- ACTION BUTTONS -->
          <div style="display: flex; justify-content: flex-end; align-items: center; margin-top: 10px; border-top: 1px solid #f1f5f9; padding-top: 20px;">
            <button type="submit" style="padding: 12px 28px; background-color: #005d6c; color: #ffffff; border: none; border-radius: 8px; font-weight: bold; font-size: 0.9rem; cursor: pointer; transition: background-color 0.15s;" onmouseover="this.style.backgroundColor='#0b6170'" onmouseout="this.style.backgroundColor='#005d6c'">
              🚀 Daftarkan Mahasiswa Baru ➔
            </button>
          </div>
        </form>
      </div>
      <!-- DATATABLE VIEW: DAFTAR SELURUH MAHASISWA AKTIF DI RAHIM DATABASE D1 -->
      <div style="background-color: #ffffff; padding: 32px; border-radius: 16px; border: 1px solid #e5e7eb; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.01);">
        <h3 style="margin: 0 0 20px 0; color: #005d6c; font-weight: 800; font-size: 1.2rem;">📋 Inventarisasi Mahasiswa Aktif SIAKAD</h3>
        
        <div style="overflow-x: auto;">
          <table style="width: 100%; border-collapse: collapse; font-size: 0.9rem; text-align: left;">
            <thead>
              <tr style="border-bottom: 2px solid #e5e7eb; color: #005d6c; font-weight: bold; background-color: #f8fafc;">
                <th style="padding: 14px 12px; width: 140px;">NOMOR INDUK (NIM)</th>
                <th style="padding: 14px 12px;">NAMA LENGKAP MAHASISWA</th>
                <th style="padding: 14px 12px; width: 150px;">KONTAK WHATSAPP</th>
                <th style="padding: 14px 12px; text-align: center; width: 130px;">BILLING SPP</th>
                <th style="padding: 14px 12px; text-align: center; width: 130px;">STATUS KRS</th>
              </tr>
            </thead>
            <tbody>
              {daftarMahasiswa.length === 0 ? (
                <tr>
                  <td colspan="5" style="padding: 24px; text-align: center; color: #64748b; font-style: italic;">
                    Belum ada mahasiswa yang terdaftar di dalam sistem SIAKAD, Doc.
                  </td>
                </tr>
              ) : (
                daftarMahasiswa.map((mhs) => (
                  <tr style="border-bottom: 1px solid #f1f5f9;">
                    <td style="padding: 14px 12px; font-weight: bold; color: #475569; font-family: monospace;">{mhs.nomor_induk}</td>
                    <td style="padding: 14px 12px; font-weight: 600; color: #111827;">{mhs.nama_lengkap}</td>
                    <td style="padding: 14px 12px; font-weight: 500; color: #374151; font-family: monospace;">+{mhs.nomor_wa || "-"}</td>
                    <td style="padding: 14px 12px; text-align: center;">
                      <span style={`padding: 4px 10px; border-radius: 6px; font-size: 0.78rem; font-weight: bold; text-transform: uppercase; ${mhs.status_spp === 'lunas' ? 'background-color: #dcfce7; color: #15803d; border: 1px solid #bbf7d0;' : 'background-color: #fee2e2; color: #991b1b; border: 1px solid #fca5a5;'}`}>
                        {mhs.status_spp || "TUNGGAKAN"}
                      </span>
                    </td>
                    <td style="padding: 14px 12px; text-align: center;">
                      <span style={`padding: 4px 10px; border-radius: 6px; font-size: 0.78rem; font-weight: bold; text-transform: uppercase; ${mhs.status_krs === 'approved' ? 'background-color: #e0f2fe; color: #0369a1;' : 'background-color: #f1f5f9; color: #475569;'}`}>
                        {mhs.status_krs || "DRAFT"}
                      </span>
                    </td>
                  </tr>
                ))
              )}
            </tbody>
          </table>
        </div>

        <div style="margin-top: 32px; text-align: center; border-top: 1px solid #f1f5f9; padding-top: 20px;">
          <a href="/admin/dashboard" style="color: #64748b; font-size: 0.9rem; font-weight: 600; text-decoration: none;">➔ Kembali ke BAAK HUB Dashboard</a>
        </div>
      </div>

    </main>
  </body>
</html>
