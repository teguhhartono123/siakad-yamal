---
// =========================================================================
// 🏛️ REPUBLIK PORTAL SIAKAD - DASHBOARD DOSEN WALI (SERVER SSR)
// 🎓 STIT YA'MAL TANGERANG - ASTRO V6 + REAL-TIME TRI-CARD WORKSPACE
// =========================================================================

// Mock session dummy kasta sultan biar langsung mekar tampan di browser
const sessionNama = "Dr. Syarifuddin, M.Pd.";
const sessionNim = "198512001";
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Dashboard Dosen Wali - SIAKAD STIT YA'MAL</title>
  </head>
  <body style="margin: 0; background-color: #f4f9fa; font-family: sans-serif; color: #1f2937;">
    
    <!-- TOP BAR PANEL NAVIGASI SULTAN -->
    <header style="background-color: #005d6c; color: #ffffff; padding: 16px 32px; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
      <div style="font-weight: 800; font-size: 1.2rem; letter-spacing: -0.3px;">🏛️ SIAKAD DOSEN WALI</div>
      <div style="display: flex; align-items: center; gap: 16px;">
        <a href="/dosen/profil" style="font-size: 0.85rem; font-weight: 700; color: #ffffff; text-decoration: none; background-color: rgba(255,255,255,0.15); padding: 8px 16px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.25); display: flex; align-items: center; gap: 6px; transition: all 0.15s;" onmouseover="this.style.backgroundColor='rgba(255,255,255,0.3)';" onmouseout="this.style.backgroundColor='rgba(255,255,255,0.15)';">
          👨‍🏫 {sessionNama} ({sessionNim}) <span style="font-size: 0.75rem;">➔</span>
        </a>
        <a href="/logout" style="color: #ffffff; font-size: 0.85rem; font-weight: bold; text-decoration: none; border: 1px solid #ffffff; padding: 6px 12px; border-radius: 6px; transition: all 0.15s;" onmouseover="this.style.backgroundColor='#ffffff'; this.style.color='#005d6c'" onmouseout="this.style.backgroundColor='transparent'; this.style.color='#ffffff'">Keluar</a>
      </div>
    </header>

    <!-- MAIN DASHBOARD COMPONENT WORKSPACE -->
    <main style="max-width: 1100px; margin: 0 auto; padding: 40px 20px;">
      
      <!-- WELCOME HERO BANNER DOSEN -->
      <div style="background-color: #ffffff; padding: 32px; border-radius: 16px; border: 1px solid #e5e7eb; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.01); margin-bottom: 30px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px;">
        <div>
          <h2 style="margin: 0; font-size: 1.8rem; color: #005d6c; font-weight: 800;">
            Selamat Datang, {sessionNama}! 🌟
          </h2>
          <p style="margin: 8px 0 0 0; color: #4b5563; font-size: 1rem; line-height: 1.5;">
            Selamat datang di Panel Manajemen Academic Dosen Wali. Di sini Anda dapat melakukan pengawasan bimbingan Kartu Rencana Studi (KRS) mahasiswa serta mengunduh rekap nilai.
          </p>
        </div>
        <a href="/dosen/profil" style="padding: 10px 20px; background-color: #f1f5f9; color: #475569; border: 1px solid #cbd5e1; border-radius: 8px; font-size: 0.88rem; font-weight: bold; text-decoration: none; transition: all 0.15s;" onmouseover="this.style.backgroundColor='#e2e8f0'; this.style.color='#005d6c';" onmouseout="this.style.backgroundColor='#f1f5f9'; this.style.color='#475569';">🔍 Lihat Detail Profil</a>
      </div>

      <!-- SAKLAR MENU HUB 3 KARTU UTAMA (SINKRONISASI 3 BLOK SEJAJAR: SIMETRIS INDAH JAYA!) -->
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px;">
        
        <!-- CARD MENU 1: PERSETUJUAN KRS -->
        <div style="background-color: #ffffff; padding: 28px; border-radius: 12px; border: 1px solid #e5e7eb; display: flex; flex-direction: column; justify-content: space-between; gap: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);">
          <div>
            <div style="font-size: 2rem;">🔒</div>
            <h3 style="margin: 8px 0 0 0; color: #005d6c; font-weight: bold; font-size: 1.25rem;">Persetujuan KRS</h3>
            <p style="margin: 8px 0 12px 0; color: #64748b; font-size: 0.88rem; line-height: 1.5;">
              Sidak dan periksa daftar antrean pengisian KRS mahasiswa bimbingan Anda. Berikan verifikasi persetujuan secara real-time.
            </p>
          </div>
          <a href="/dosen/krs-approval" style="text-align: center; padding: 12px; background-color: #005d6c; color: #ffffff; text-decoration: none; border-radius: 8px; font-weight: bold; font-size: 0.9rem; transition: background-color 0.15s;" onmouseover="this.style.backgroundColor='#0b6170'" onmouseout="this.style.backgroundColor='#005d6c'">Periksa Antrean KRS ➔</a>
        </div>

        <!-- CARD MENU 2: INPUT NILAI KHS -->
        <div style="background-color: #ffffff; padding: 28px; border-radius: 12px; border: 1px solid #e5e7eb; display: flex; flex-direction: column; justify-content: space-between; gap: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);">
          <div>
            <div style="font-size: 2rem;">✍️</div>
            <h3 style="margin: 8px 0 0 0; color: #005d6c; font-weight: bold; font-size: 1.25rem;">Input Nilai Akhir (KHS)</h3>
            <p style="margin: 8px 0 12px 0; color: #64748b; font-size: 0.88rem; line-height: 1.5;">
              Masukkan komponen nilai tugas, UTS, dan UAS mahasiswa per mata kuliah semester ganjil untuk konversi otomatis IPK server.
            </p>
          </div>
          <a href="/dosen/input-nilai" style="text-align: center; padding: 12px; background-color: #005d6c; color: #ffffff; text-decoration: none; border-radius: 8px; font-weight: bold; font-size: 0.9rem; transition: background-color 0.15s;" onmouseover="this.style.backgroundColor='#0b6170'" onmouseout="this.style.backgroundColor='#005d6c'">Mulai Input Nilai ➔</a>
        </div>

        <!-- 🟢 CARD MENU 3 BARU: SAKLAR JURNAL ABSENSI KELAS DIGITAL REAL-TIME (SPEK UNGU ELEGAN) -->
        <div style="background-color: #ffffff; padding: 28px; border-radius: 12px; border: 1px solid #e5e7eb; border-top: 5px solid #7c3aed; display: flex; flex-direction: column; justify-content: space-between; gap: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);">
          <div>
            <div style="font-size: 2rem;">📝</div>
            <h3 style="margin: 8px 0 0 0; color: #7c3aed; font-weight: bold; font-size: 1.25rem;">Jurnal Absensi Kelas</h3>
            <p style="margin: 8px 0 12px 0; color: #64748b; font-size: 0.88rem; line-height: 1.5;">
              Buka lembar kehadiran kuliah harian mahasiswa aktif secara digital. Amankan mutasi kehadiran langsung ke database serverless D1.
            </p>
          </div>
          <a href="/dosen/absensi" style="text-align: center; padding: 12px; background-color: #7c3aed; color: #ffffff; text-decoration: none; border-radius: 8px; font-weight: bold; font-size: 0.9rem; transition: background-color 0.15s; box-shadow: 0 4px 6px -1px rgba(124, 58, 237, 0.15);" onmouseover="this.style.backgroundColor='#6d28d9'" onmouseout="this.style.backgroundColor='#7c3aed'">Buka Absensi Kuliah ➔</a>
        </div>

      </div>

    </main>
  </body>
</html>
