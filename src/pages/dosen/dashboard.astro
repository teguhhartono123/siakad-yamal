---
// =========================================================================
// 🏛️ REPUBLIK PORTAL SIAKAD - PRIVAT DASHBOARD DOSEN WALI (SERVER-SIDE SSR)
// 🎓 STIT YA'MAL TANGERANG - 100% AMAN JAYA & SPEK ENTERPRISE DOSEN GUARD
// =========================================================================

// 🛡️ GATEKEEPER PROTECTION: Blokir dan tendang paksa jika ada mahasiswa atau penyusup coba-coba masuk!
const sessionNim = Astro.cookies.get("siakad_session_nim")?.value;
const sessionNama = Astro.cookies.get("siakad_session_nama")?.value;
const sessionRole = Astro.cookies.get("siakad_session_role")?.value;

if (!sessionNim || sessionRole !== "dosen") {
  return Astro.redirect('/login');
}
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Dashboard Dosen - SIAKAD STIT YA'MAL</title>
  </head>
  <body style="margin: 0; background-color: #f4f9fa; font-family: sans-serif; color: #1f2937;">
    
    <!-- TOP BAR PANEL NAVIGASI SULTAN -->
    <header style="background-color: #005d6c; color: #ffffff; padding: 16px 32px; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
      <div style="font-weight: 800; font-size: 1.2rem; letter-spacing: -0.3px;">🏛️ SIAKAD DOSEN WALI</div>
      <div style="display: flex; align-items: center; gap: 16px;">
        <span style="font-size: 0.9rem; font-weight: 600; background-color: rgba(255,255,255,0.15); padding: 6px 12px; border-radius: 6px;">
          👨‍🏫 {sessionNama} ({sessionNim})
        </span>
        <a href="/logout" style="color: #ffffff; font-size: 0.85rem; font-weight: bold; text-decoration: none; border: 1px solid #ffffff; padding: 6px 12px; border-radius: 6px; transition: all 0.15s;" onmouseover="this.style.backgroundColor='#ffffff'; this.style.color='#005d6c'" onmouseout="this.style.backgroundColor='transparent'; this.style.color='#ffffff'">Keluar</a>
      </div>
    </header>

    <!-- MAIN DASHBOARD WORKSPACE -->
    <main style="max-width: 1100px; margin: 0 auto; padding: 40px 20px;">
      
      <!-- WELCOME HERO BANNER DOSEN -->
      <div style="background-color: #ffffff; padding: 32px; border-radius: 16px; border: 1px solid #e5e7eb; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.01); margin-bottom: 30px;">
        <h2 style="margin: 0; font-size: 1.8rem; color: #005d6c; font-weight: 800;">
          Selamat Datang, {sessionNama}! 🌟
        </h2>
        <p style="margin: 8px 0 0 0; color: #4b5563; font-size: 1rem; line-height: 1.5;">
          Selamat datang di Panel Manajemen Akademik Dosen Wali. Di sini Anda dapat melakukan pengawasan bimbingan Kartu Rencana Studi (KRS) mahasiswa serta mengunduh rekap nilai.
        </p>
      </div>

      <!-- SAKLAR MENU HUB DOSEN WALI -->
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px;">
        
        <!-- MENU CARD 1: PERSETUJUAN KRS MAHASISWA -->
        <div style="background-color: #ffffff; padding: 28px; border-radius: 12px; border: 1px solid #e5e7eb; display: flex; flex-direction: column; gap: 12px;">
          <div style="font-size: 2rem;">🔒</div>
          <h3 style="margin: 0; color: #005d6c; font-weight: bold; font-size: 1.25rem;">Persetujuan KRS Mahasiswa</h3>
          <p style="margin: 0; color: #64748b; font-size: 0.88rem; line-height: 1.5; flex-grow: 1;">
            Sidak dan periksa daftar antrean pengisian KRS mahasiswa bimbingan Anda. Berikan verifikasi persetujuan secara real-time.
          </p>
          <a href="/dosen/krs-approval" style="text-align: center; margin-top: 12px; padding: 12px; background-color: #005d6c; color: #ffffff; text-decoration: none; border-radius: 8px; font-weight: bold; font-size: 0.9rem; transition: background-color 0.15s;" onmouseover="this.style.backgroundColor='#0b6170'" onmouseout="this.style.backgroundColor='#005d6c'">Periksa Antrean KRS ➔</a>
        </div>

        <!-- MENU CARD 2: INPUT NILAI KHS -->
        <div style="background-color: #ffffff; padding: 28px; border-radius: 12px; border: 1px solid #e5e7eb; display: flex; flex-direction: column; gap: 12px;">
          <div style="font-size: 2rem;">✍️</div>
          <h3 style="margin: 0; color: #005d6c; font-weight: bold; font-size: 1.25rem;">Input Nilai Akhir (KHS)</h3>
          <p style="margin: 0; color: #64748b; font-size: 0.88rem; line-height: 1.5; flex-grow: 1;">
            Masukkan komponen nilai tugas, UTS, dan UAS mahasiswa per mata kuliah semester ganjil untuk konversi otomatis IPK server.
          </p>
          <a href="/dosen/input-nilai" style="text-align: center; margin-top: 12px; padding: 12px; background-color: #005d6c; color: #ffffff; text-decoration: none; border-radius: 8px; font-weight: bold; font-size: 0.9rem; transition: background-color 0.15s;" onmouseover="this.style.backgroundColor='#0b6170'" onmouseout="this.style.backgroundColor='#005d6c'">Mulai Input Nilai ➔</a>
        </div>

      </div>

    </main>
  </body>
</html>
